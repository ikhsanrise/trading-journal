generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String           @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  accounts        Account[]
  sessions        Session[]
  setups          Setup[]
  tradingAccounts TradingAccount[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TradingAccount {
  id             String   @id @default(cuid())
  userId         String
  name           String
  broker         String
  currency       String   @default("USD")
  initialBalance Float
  currentBalance Float
  assetClass     String   @default("forex")
  isDefault      Boolean  @default(false)
  monthlyGoal    Float?   @default(0)
  totalDeposit   Float    @default(0)
  totalWithdraw  Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  trades         Trade[]
  transactions   Transaction[]

  @@index([userId])
  @@index([userId, isDefault])
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trade {
  id               String         @id @default(cuid())
  accountId        String
  symbol           String
  direction        String
  entryPrice       Float
  exitPrice        Float?
  stopLoss         Float?
  takeProfit       Float?
  lotSize          Float
  entryDate        DateTime
  exitDate         DateTime?
  commission       Float          @default(0)
  swap             Float          @default(0)
  pnl              Float?
  rMultiple        Float?
  status           String         @default("open")
  outcome          String?
  setupId          String?
  session          String?
  timeframe        String?
  notes            String?
  mood             Int?
  screenshotBefore String?
  screenshotAfter  String?
  tags             String[]       @default([])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  setupCategory    String?
  account          TradingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  setup            Setup?         @relation(fields: [setupId], references: [id])

  @@index([accountId])
  @@index([accountId, status])
  @@index([accountId, entryDate])
}

model Transaction {
  id          String         @id @default(cuid())
  accountId   String
  type        String         // "deposit" | "withdraw"
  amount      Float
  note        String?
  date        DateTime       @default(now())
  account     TradingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model Setup {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  rules       String?
  timeframe   String?
  expectedRR  Float?
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades      Trade[]
}
